# Copy this file to .env and fill in your keys
# .env is gitignored and will never be committed

# Anthropic (required)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Amadeus flight search (required for flight search)
# Get free test credentials at: https://developers.amadeus.com
AMADEUS_CLIENT_ID=your-amadeus-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-client-secret

# RapidAPI Hotels4 (required for hotel search)
# Subscribe at: https://rapidapi.com/apidojo/api/hotels4
RAPIDAPI_KEY=your-rapidapi-key

# Apify (required for Airbnb search)
# Get token at: https://apify.com
APIFY_TOKEN=your-apify-token
APIFY_ACTOR_ID=NDa1latMCCFtEgm6d
APIFY_LOCATION_FIELD=locationQuery
